 {
  "compilerOptions": {
    "target": "esnext",
    "strict": true,
    "preserveConstEnums": true,
    "sourceMap": false,
    "module":"nodenext",
    "moduleResolution":"nodenext",
    "esModuleInterop": true, 
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true, 
    "isolatedModules": true, 
    "outDir": "dist"
  },
  "exclude": ["node_modules", "**/*.test.ts"]
}
